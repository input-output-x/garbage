<view class="page">
  <view class="addr-card" wx:for="{{list}}" wx:key="id">
    <view class="addr-main" data-id="{{item.id}}" bindtap="edit">
      <view class="addr-top">
        <text class="addr-name">{{item.contactName}}</text>
        <text class="addr-phone">{{item.contactPhone}}</text>
        <text class="addr-default" wx:if="{{item.isDefault}}">默认</text>
      </view>
      <text class="addr-detail">{{item.communityName}} {{item.building}}{{item.unit !== '-' ? item.unit + '单元' : ''}}{{item.room}}</text>
    </view>
    <view class="addr-actions">
      <text data-id="{{item.id}}" bindtap="setDefault" wx:if="{{!item.isDefault}}">设为默认</text>
      <text data-id="{{item.id}}" bindtap="deleteAddr">删除</text>
    </view>
  </view>
  <view class="empty" wx:if="{{!list.length}}">暂无地址，请添加</view>
  <button class="btn-primary add-btn" bindtap="add">新增地址</button>
</view>
