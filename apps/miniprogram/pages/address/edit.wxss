.page { padding: 24rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 0 24rpx; }
.row {
  display: flex; align-items: center; padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.row:last-child { border-bottom: none; }
.label { width: 140rpx; font-size: 28rpx; color: #666; flex-shrink: 0; }
.row input { flex: 1; font-size: 28rpx; }
.value { flex: 1; font-size: 28rpx; }
.arrow { color: #ccc; }
.switch-row { justify-content: space-between; }
.save-btn { margin-top: 48rpx; }
