<view class="page">
  <view class="card">
    <textarea
      class="textarea"
      placeholder="请描述您的问题或建议..."
      data-field="content"
      bindinput="onInput"
      maxlength="500"
    />
    <input class="input" placeholder="联系电话（选填）" data-field="phone" bindinput="onInput" type="number" />
  </view>
  <button class="btn-primary submit-btn" bindtap="submit">提交反馈</button>
</view>
