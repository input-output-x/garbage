.page {
  padding-bottom: 180rpx;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.type-tag {
  font-size: 34rpx;
  font-weight: 600;
}

.price-tag {
  font-size: 26rpx;
  color: #FF8A00;
}

.qty-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #F5F5F5;
}

.qty-label {
  font-size: 28rpx;
  color: #666;
}

.qty-ctrl {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid #FF8A00;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FF8A00;
  line-height: 1;
}

.qty-num {
  font-size: 32rpx;
  font-weight: 600;
  min-width: 40rpx;
  text-align: center;
}

.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; display: flex; justify-content: space-between; }
.card-title .link { font-size: 26rpx; color: #FF8A00; font-weight: 400; }
.pkg-row {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 24rpx; padding-top: 24rpx; border-top: 1rpx solid #F5F5F5;
  font-size: 26rpx; color: #666;
}
.addr-option {
  padding: 20rpx; border: 2rpx solid #F0F0F0; border-radius: 12rpx;
  margin-bottom: 12rpx; font-size: 26rpx;
}
.addr-option.active { border-color: #FF8A00; background: #FFF8F0; }
.manual-link { text-align: center; color: #FF8A00; font-size: 26rpx; padding: 12rpx; }

.input-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.input-row:last-child {
  border-bottom: none;
}

.input-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  padding: 16rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
}

.tip-bar {
  margin: 0 24rpx;
  padding: 16rpx 24rpx;
  background: #FFF8F0;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #B8860B;
  text-align: center;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.footer-price {
  flex: 1;
}

.footer-label {
  font-size: 22rpx;
  color: #999;
  margin-right: 8rpx;
}

.footer-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF8A00;
}

.footer-btn {
  width: 280rpx;
  flex-shrink: 0;
}
