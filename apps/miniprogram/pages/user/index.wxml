<view class="page">
  <!-- 用户信息头 -->
  <view class="header">
    <view class="header-bg"></view>
    <view class="profile" bindtap="onProfileTap">
      <view class="avatar-wrap">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="profile-info">
        <text class="nickname">{{user ? user.nickname : '点击登录'}}</text>
        <text class="member-id" wx:if="{{user}}">会员ID {{memberId}}</text>
        <text class="member-days" wx:if="{{user}}">丢呗已陪伴您 {{days}} 天</text>
      </view>
      <text class="profile-arrow">›</text>
    </view>
  </view>

  <!-- VIP 卡片 -->
  <view class="vip-card">
    <view class="vip-left">
      <text class="vip-title">VIP 会员</text>
      <text class="vip-desc">开通 VIP，享优惠服务</text>
    </view>
    <view class="vip-btn" bindtap="openVip">立即开通</view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goAddress">
      <text class="menu-icon">📍</text>
      <text class="menu-label">我的地址</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goFeedback">
      <text class="menu-icon">💬</text>
      <text class="menu-label">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-service" bindtap="contactService">
      <text class="service-icon">🎧</text>
      <text>联系客服</text>
    </view>
  </view>
</view>
