.page {
  min-height: 100vh;
  background: #F5F6F8;
}

.header {
  position: relative;
  padding-bottom: 16rpx;
}

.header-bg {
  height: 280rpx;
  background: linear-gradient(160deg, #FFD080 0%, #FFB347 60%, #FF9A3D 100%);
}

.profile {
  position: relative;
  margin: -80rpx 24rpx 0;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(255, 138, 0, 0.12);
}

.avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFE0B2, #FFB347);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 48rpx;
}

.profile-info {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.nickname {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.member-id {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.member-days {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #FF8A00;
}

.profile-arrow {
  color: #ccc;
  font-size: 36rpx;
}

/* VIP */
.vip-card {
  margin: 24rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #3D3028, #5C4A3A);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vip-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFD080;
  font-style: italic;
}

.vip-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 208, 128, 0.7);
}

.vip-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #FFB347, #FF8A00);
  color: #fff;
  font-size: 24rpx;
  border-radius: 32rpx;
  flex-shrink: 0;
}

/* Menu */
.menu-card {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.menu-service {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx;
  color: #FF8A00;
  font-size: 28rpx;
}

.service-icon {
  font-size: 32rpx;
}
