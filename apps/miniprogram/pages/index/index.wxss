.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

/* Hero */
.hero {
  position: relative;
  background: linear-gradient(160deg, #FFD080 0%, #FFB347 45%, #FF9A3D 100%);
  padding: 32rpx 32rpx 56rpx;
  overflow: hidden;
}

.hero-inner {
  position: relative;
  z-index: 1;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.brand-logo {
  width: 48rpx;
  height: 48rpx;
  background: #FF8A00;
  border-radius: 12rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.hero-slogan {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.3;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(26, 26, 26, 0.65);
}

.hero-illus {
  position: absolute;
  right: 16rpx;
  bottom: 8rpx;
  font-size: 120rpx;
  opacity: 0.85;
  z-index: 0;
}

.notice-bar {
  display: flex;
  align-items: center;
  margin: -28rpx 24rpx 16rpx;
  padding: 20rpx 24rpx;
  background: #FFFBF0;
  border-radius: 16rpx;
  border: 1rpx solid #FFE4B5;
  position: relative;
  z-index: 2;
}
.notice-bar .notice-icon { font-size: 28rpx; margin-right: 8rpx; }
.notice-bar .notice-text {
  flex: 1;
  font-size: 24rpx;
  color: #996600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.notice-btn {
  padding: 6rpx 16rpx;
  border: 1rpx solid #FF8A00;
  color: #FF8A00;
  font-size: 22rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.location-bar {
  display: flex;
  align-items: center;
  margin: 0 24rpx 20rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.location-text { flex: 1; margin-left: 8rpx; font-size: 28rpx; }

.partner-bar {
  margin: 0 24rpx 20rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #FFF0D6, #FFE4B5);
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.partner-title { display: block; font-size: 30rpx; font-weight: 600; color: #8B4513; }
.partner-desc { display: block; margin-top: 6rpx; font-size: 22rpx; color: #A0522D; }
.partner-icon { font-size: 48rpx; }

.service-btn-alt { background: linear-gradient(135deg, #FF9A3D, #FF7A00); }

.review-card { margin-top: 0; }
.review-item { padding: 20rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.review-item:last-child { border-bottom: none; }
.review-top { display: flex; justify-content: space-between; align-items: flex-start; }
.review-user { display: flex; gap: 16rpx; }
.review-avatar {
  width: 64rpx; height: 64rpx; background: #FFD080; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600; color: #fff;
}
.review-name { display: block; font-size: 28rpx; font-weight: 500; }
.review-meta { display: block; margin-top: 4rpx; font-size: 22rpx; color: #999; }
.review-rating { font-size: 24rpx; color: #FF8A00; white-space: nowrap; }

/* Notice - old removed */
.notice {
  display: flex;
  align-items: center;
  margin: -28rpx 24rpx 24rpx;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(255, 138, 0, 0.1);
  position: relative;
  z-index: 2;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.notice-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-arrow {
  color: #ccc;
  font-size: 36rpx;
}

/* Service cards */
.service-row {
  display: flex;
  gap: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.service-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.service-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.service-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
}

.service-btn {
  display: inline-block;
  margin-top: 20rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #FFB347, #FF8A00);
  color: #fff;
  font-size: 22rpx;
  border-radius: 24rpx;
}

.service-icon {
  font-size: 72rpx;
  line-height: 1;
}

/* Flow */
.flow-card {
  margin-top: 0;
}

.flow-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.flow-title {
  font-size: 32rpx;
  font-weight: 600;
}

.flow-link {
  font-size: 24rpx;
  color: #FF8A00;
}

.flow-steps {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.flow-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.flow-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #FFF5EB;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.flow-icon {
  font-size: 36rpx;
}

.flow-label {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.flow-arrow {
  position: absolute;
  right: -8rpx;
  top: 28rpx;
  color: #ddd;
  font-size: 28rpx;
}

/* Tip */
.tip-bar {
  margin: 0 24rpx;
  padding: 20rpx 24rpx;
  background: #FFF8F0;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #B8860B;
  text-align: center;
  line-height: 1.5;
}

/* Type picker */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.picker-sheet {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
}

.picker-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 28rpx 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.picker-info {
  flex: 1;
}

.picker-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
}

.picker-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #999;
}

.picker-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.picker-cancel {
  margin-top: 16rpx;
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 28rpx;
}
